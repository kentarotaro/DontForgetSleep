{
  "name": "functions",
  "version": "1.0.0",
  "description": "Firebase Cloud Functions for D.F.S Backend",
  "main": "lib/index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "dependencies": {
    "@google/genai": "^2.3.0",
    "firebase-admin": "^13.1.0",
    "firebase-functions": "^6.3.1",
    "googleapis": "^144.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "typescript": "^5.7.3"
  },
  "private": true
}
